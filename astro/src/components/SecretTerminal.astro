---
// SecretTerminal.astro
// Drop this anywhere on your site. Activated by typing the konami-style
// trigger sequence, then unlocked with your passkey.
// The passkey is NEVER in this file — it's checked server-side only.
---

<div id="st-portal" aria-hidden="true"></div>

<style>
  /* ── OVERLAY ── */
  #st-overlay {
    position: fixed; inset: 0; z-index: 9999;
    background: rgba(10, 5, 20, 0.85);
    backdrop-filter: blur(6px);
    display: flex; align-items: center; justify-content: center;
    opacity: 0; pointer-events: none;
    transition: opacity 0.25s;
  }
  #st-overlay.open { opacity: 1; pointer-events: all; }

  /* ── WINDOW ── */
  #st-win {
    width: min(680px, 94vw);
    background: #160420;
    border: 1.5px solid #7a40b0;
    border-radius: 14px;
    overflow: hidden;
    box-shadow: 0 0 60px rgba(140, 60, 220, 0.35), 0 0 0 1px rgba(180,100,255,0.08);
    transform: translateY(12px);
    transition: transform 0.25s;
    font-family: 'Space Mono', monospace;
  }
  #st-overlay.open #st-win { transform: translateY(0); }

  /* ── CHROME ── */
  #st-chrome {
    background: linear-gradient(135deg, #7a2898, #a040c8);
    padding: 7px 12px;
    display: flex; align-items: center; gap: 7px;
  }
  .st-dot { width: 10px; height: 10px; border-radius: 50%; border: 1px solid rgba(0,0,0,0.2); }
  .st-dot.r { background: #f4a0b0; } .st-dot.y { background: #f9d88a; } .st-dot.g { background: #90e0b0; }
  #st-chrome-title {
    font-family: 'VT323', monospace; font-size: 14px;
    color: rgba(255,255,255,0.9); margin-left: 4px; letter-spacing: 0.5px;
  }
  #st-close {
    margin-left: auto; background: none; border: none;
    color: rgba(255,255,255,0.5); cursor: pointer; font-size: 16px;
    padding: 0 2px; line-height: 1;
  }
  #st-close:hover { color: #f4a0b0; }

  /* ── BODY ── */
  #st-body { padding: 16px; }

  /* ── OUTPUT STREAM ── */
  #st-output {
    height: 180px; overflow-y: auto;
    background: #0e0218; border: 1px solid #3a1a60;
    border-radius: 8px; padding: 10px 12px;
    margin-bottom: 12px;
    font-family: 'VT323', monospace; font-size: 15px; line-height: 1.7;
    scrollbar-width: thin; scrollbar-color: #5a2080 #0e0218;
  }
  .st-line-sys  { color: #9060b8; }
  .st-line-ok   { color: #70e0b0; }
  .st-line-err  { color: #f4a0b0; }
  .st-line-info { color: #c8a8e8; }
  .st-line-dim  { color: #4a3060; }
  .st-line-bold { color: #e0c8ff; font-weight: bold; }

  /* ── PHASE: AUTH ── */
  #st-auth { display: flex; gap: 8px; align-items: center; margin-bottom: 12px; }
  #st-passkey-input {
    flex: 1; background: #0e0218; border: 1px solid #5a2080;
    border-radius: 8px; padding: 8px 12px;
    font-family: 'VT323', monospace; font-size: 16px;
    color: #e0c8ff; letter-spacing: 3px; outline: none;
    transition: border-color 0.2s;
  }
  #st-passkey-input:focus { border-color: #a060e0; }
  #st-passkey-input::placeholder { letter-spacing: 1px; color: #3a1a60; }
  .st-btn {
    background: #2a0e48; border: 1.5px solid #7040b0;
    border-radius: 8px; padding: 7px 16px;
    font-family: 'VT323', monospace; font-size: 15px;
    color: #c8a0f0; cursor: pointer; transition: all 0.15s; white-space: nowrap;
  }
  .st-btn:hover { background: #3d1a60; color: #e8d0ff; border-color: #a060e0; }
  .st-btn:disabled { opacity: 0.4; cursor: not-allowed; }

  /* ── PHASE: EDITOR ── */
  #st-editor { display: none; flex-direction: column; gap: 8px; }
  #st-editor.visible { display: flex; }

  .st-field-row { display: flex; gap: 8px; }

  .st-field {
    background: #0e0218; border: 1px solid #3a1a60; border-radius: 8px;
    padding: 7px 10px; font-family: 'VT323', monospace; font-size: 15px;
    color: #e0c8ff; outline: none; width: 100%; transition: border-color 0.2s;
    resize: none;
  }
  .st-field:focus { border-color: #a060e0; }
  .st-field::placeholder { color: #3a1a60; }

  #st-body-input { height: 100px; line-height: 1.6; font-size: 14px; }

  .st-actions { display: flex; gap: 8px; align-items: center; margin-top: 2px; }
  #st-char-count { font-family: 'VT323', monospace; font-size: 13px; color: #4a3060; margin-left: auto; }

  /* ── HASH DISPLAY ── */
  #st-hash-bar {
    margin-top: 10px; padding: 6px 10px;
    background: #0a0115; border: 1px solid #2a1040; border-radius: 6px;
    font-family: 'VT323', monospace; font-size: 12px; color: #4a3060;
    letter-spacing: 0.5px; display: none;
  }
  #st-hash-bar.visible { display: block; }
  #st-hash-val { color: #7040a8; }
</style>

<script>
// ════════════════════════════════════════════════════════════
//  SECRET TERMINAL — client-side controller
//  Architecture note: passkey validation happens in /api/log
//  (server-side Vercel function). This file never sees the key.
// ════════════════════════════════════════════════════════════

(function () {
  // ── Trigger sequence: type "mia" anywhere on the page ──
  const TRIGGER = 'mia';
  let keyBuffer = '';

  // ── Session state — stored as a hash map ──
  // Using a plain object as a hash map: O(1) lookup for each field.
  // Keys: 'unlocked', 'token', 'title', 'body', 'tags'
  const session = new Map([
    ['unlocked', false],
    ['token',    null],
    ['title',    ''],
    ['body',     ''],
    ['tags',     ''],
  ]);

  // ── Build the DOM (injected, not in static HTML so it's truly hidden) ──
  const portal = document.getElementById('st-portal');
  portal.innerHTML = `
    <div id="st-overlay">
      <div id="st-win" role="dialog" aria-modal="true" aria-label="Secret terminal">
        <div id="st-chrome">
          <span class="st-dot r"></span>
          <span class="st-dot y"></span>
          <span class="st-dot g"></span>
          <span id="st-chrome-title">terminal — private access ✦</span>
          <button id="st-close" aria-label="Close terminal">✕</button>
        </div>
        <div id="st-body">
          <div id="st-output" role="log" aria-live="polite"></div>

          <div id="st-auth">
            <input id="st-passkey-input" type="password"
              placeholder="enter passkey..." autocomplete="off" spellcheck="false" />
            <button class="st-btn" id="st-auth-btn">unlock →</button>
          </div>

          <div id="st-editor">
            <input  class="st-field" id="st-title-input" type="text"
              placeholder="entry title..." maxlength="120" />
            <div class="st-field-row">
              <input class="st-field" id="st-tags-input" type="text"
                placeholder="tags: astro, alignment, wip" maxlength="80" />
              <input class="st-field" id="st-date-input" type="date"
                style="width:160px;flex-shrink:0;" />
            </div>
            <textarea class="st-field" id="st-body-input"
              placeholder="write your log entry... (markdown supported)"
              maxlength="4000"></textarea>
            <div class="st-actions">
              <button class="st-btn" id="st-submit-btn">commit entry →</button>
              <button class="st-btn" id="st-clear-btn" style="opacity:0.6;">clear</button>
              <span id="st-char-count">0 / 4000</span>
            </div>
          </div>

          <div id="st-hash-bar">
            <span style="color:#3a1a60;">sha·entry: </span>
            <span id="st-hash-val">—</span>
          </div>
        </div>
      </div>
    </div>
  `;

  // ── Element refs ──
  const overlay   = document.getElementById('st-overlay');
  const output    = document.getElementById('st-output');
  const authDiv   = document.getElementById('st-auth');
  const passInput = document.getElementById('st-passkey-input');
  const authBtn   = document.getElementById('st-auth-btn');
  const editor    = document.getElementById('st-editor');
  const titleInp  = document.getElementById('st-title-input');
  const bodyInp   = document.getElementById('st-body-input');
  const tagsInp   = document.getElementById('st-tags-input');
  const dateInp   = document.getElementById('st-date-input');
  const submitBtn = document.getElementById('st-submit-btn');
  const clearBtn  = document.getElementById('st-clear-btn');
  const closeBtn  = document.getElementById('st-close');
  const charCount = document.getElementById('st-char-count');
  const hashBar   = document.getElementById('st-hash-bar');
  const hashVal   = document.getElementById('st-hash-val');

  // Set default date to today
  dateInp.value = new Date().toISOString().split('T')[0];

  // ── Output helpers ──
  function print(text, cls = 'st-line-info') {
    const line = document.createElement('div');
    line.className = cls;
    line.textContent = text;
    output.appendChild(line);
    output.scrollTop = output.scrollHeight;
  }
  function printSys(t)  { print(t, 'st-line-sys'); }
  function printOk(t)   { print(t, 'st-line-ok'); }
  function printErr(t)  { print(t, 'st-line-err'); }
  function printDim(t)  { print(t, 'st-line-dim'); }

  // ── Simple hash (djb2) for client-side entry fingerprinting ──
  // This is purely cosmetic / educational — shows a hash of the entry content.
  // Real security comes from server-side passkey validation.
  function djb2(str) {
    let h = 5381;
    for (let i = 0; i < str.length; i++) {
      h = ((h << 5) + h) ^ str.charCodeAt(i);
      h = h >>> 0; // keep as unsigned 32-bit
    }
    return h.toString(16).padStart(8, '0');
  }

  function updateHash() {
    const content = titleInp.value + bodyInp.value + tagsInp.value;
    if (content.trim()) {
      const h = djb2(content);
      hashVal.textContent = h;
      hashBar.classList.add('visible');
    } else {
      hashBar.classList.remove('visible');
    }
  }

  // ── Open / close ──
  function openTerminal() {
    overlay.classList.add('open');
    overlay.removeAttribute('aria-hidden');
    if (!session.get('unlocked')) {
      printSys('mia·os terminal v1.0 ✦');
      printSys('━━━━━━━━━━━━━━━━━━━━━━━━');
      printDim('// private log interface — passkey required');
      printDim('// entries commit directly to your GitHub repo');
      printDim('// using sha-based content-addressable storage ✿');
      printSys('');
      print('enter passkey to unlock:', 'st-line-info');
      passInput.focus();
    } else {
      titleInp.focus();
    }
  }

  function closeTerminal() {
    overlay.classList.remove('open');
    overlay.setAttribute('aria-hidden', 'true');
  }

  closeBtn.addEventListener('click', closeTerminal);
  overlay.addEventListener('click', (e) => { if (e.target === overlay) closeTerminal(); });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && overlay.classList.contains('open')) closeTerminal();
  });

  // ── Trigger: type TRIGGER sequence anywhere (not in an input) ──
  document.addEventListener('keypress', (e) => {
    if (e.target.tagName === 'INPUT' || e.target.tagName === 'TEXTAREA') return;
    keyBuffer += e.key.toLowerCase();
    if (keyBuffer.length > TRIGGER.length) keyBuffer = keyBuffer.slice(-TRIGGER.length);
    if (keyBuffer === TRIGGER) { openTerminal(); keyBuffer = ''; }
  });

  // ── Auth ──
  async function attemptAuth() {
    const key = passInput.value.trim();
    if (!key) { printErr('! no passkey entered'); return; }

    authBtn.disabled = true;
    passInput.disabled = true;
    printSys('validating passkey...');

    try {
      const res = await fetch('/api/log', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ action: 'auth', passkey: key }),
      });
      const data = await res.json();

      if (res.ok && data.ok) {
        session.set('unlocked', true);
        session.set('token', key); // keep for later submission
        printOk('✓ access granted — welcome back, Mia');
        printDim('// session stored in memory only — not persisted to disk');
        printSys('');
        print('ready. write your entry below ↓', 'st-line-bold');
        authDiv.style.display = 'none';
        editor.classList.add('visible');
        titleInp.focus();
      } else {
        printErr(`✗ ${data.error || 'incorrect passkey'}`);
        authBtn.disabled = false;
        passInput.disabled = false;
        passInput.value = '';
        passInput.focus();
      }
    } catch (err) {
      printErr('✗ connection error — is the dev server running?');
      authBtn.disabled = false;
      passInput.disabled = false;
    }
  }

  authBtn.addEventListener('click', attemptAuth);
  passInput.addEventListener('keydown', (e) => { if (e.key === 'Enter') attemptAuth(); });

  // ── Char count + live hash ──
  bodyInp.addEventListener('input', () => {
    charCount.textContent = `${bodyInp.value.length} / 4000`;
    updateHash();
  });
  titleInp.addEventListener('input', updateHash);
  tagsInp.addEventListener('input', updateHash);

  // ── Submit ──
  async function submitEntry() {
    const title = titleInp.value.trim();
    const body  = bodyInp.value.trim();
    const tags  = tagsInp.value.split(',').map(t => t.trim()).filter(Boolean);
    const date  = dateInp.value || new Date().toISOString().split('T')[0];

    if (!title) { printErr('! title required'); titleInp.focus(); return; }
    if (!body)  { printErr('! body required');  bodyInp.focus();  return; }

    submitBtn.disabled = true;
    clearBtn.disabled  = true;

    const entryHash = djb2(title + body + tags.join(''));
    printSys('');
    printSys(`committing entry...`);
    printDim(`sha·entry: ${entryHash}`);

    try {
      const res = await fetch('/api/log', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          action: 'commit',
          passkey: session.get('token'),
          title, body, tags, date,
        }),
      });
      const data = await res.json();

      if (res.ok && data.ok) {
        printOk(`✓ committed → ${data.filename}`);
        printDim(`sha·github: ${data.sha?.slice(0, 8) || '????????'}`);
        printOk('✓ vercel will redeploy automatically (~30s)');
        printDim('// your log is now part of the git history ✿');

        // Clear fields
        titleInp.value = '';
        bodyInp.value  = '';
        tagsInp.value  = '';
        dateInp.value  = new Date().toISOString().split('T')[0];
        charCount.textContent = '0 / 4000';
        hashBar.classList.remove('visible');
      } else {
        printErr(`✗ ${data.error || 'commit failed — check API logs'}`);
      }
    } catch (err) {
      printErr('✗ network error — entry not saved');
    }

    submitBtn.disabled = false;
    clearBtn.disabled  = false;
  }

  submitBtn.addEventListener('click', submitEntry);

  clearBtn.addEventListener('click', () => {
    titleInp.value = '';
    bodyInp.value  = '';
    tagsInp.value  = '';
    charCount.textContent = '0 / 4000';
    hashBar.classList.remove('visible');
    output.innerHTML = '';
    printSys('cleared ✿');
  });

})();
</script>